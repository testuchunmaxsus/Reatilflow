# ============================================================
# RETAIL — .env.example
# Ushbu faylni .env ga nusxalab, real qiymatlar bilan to'ldiring.
# Hech qachon .env faylini git'ga qo'shmang!
# ============================================================

# ─── PostgreSQL (Primary) ───────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=retail
POSTGRES_USER=retail_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# Async SQLAlchemy DSN (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://retail_user:CHANGE_ME_strong_password_here@localhost:5432/retail

# O'qish replikasi (keyinchalik sozlanadi)
DATABASE_REPLICA_URL=postgresql+asyncpg://retail_user:CHANGE_ME_strong_password_here@localhost:5433/retail

# ─── TimescaleDB (GPS izlari) ───────────────────────────────
TIMESCALE_HOST=localhost
TIMESCALE_PORT=5434
TIMESCALE_DB=retail_gps
TIMESCALE_USER=retail_gps_user
TIMESCALE_PASSWORD=CHANGE_ME_timescale_password_here
TIMESCALE_URL=postgresql+asyncpg://retail_gps_user:CHANGE_ME_timescale_password_here@localhost:5434/retail_gps

# ─── Redis ─────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password_here
REDIS_URL=redis://:CHANGE_ME_redis_password_here@localhost:6379/0

# Redis DB indekslari
REDIS_DB_SESSION=0
REDIS_DB_CACHE=1
REDIS_DB_QUEUE=2

# ─── MinIO (Object Storage) ─────────────────────────────────
MINIO_HOST=localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=CHANGE_ME_minio_root_user
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_root_password_here
MINIO_BUCKET_PRODUCTS=retail-products
MINIO_BUCKET_CONTRACTS=retail-contracts
MINIO_BUCKET_PROOFS=retail-delivery-proofs
MINIO_ENDPOINT_URL=http://localhost:9000

# ─── JWT / Auth ─────────────────────────────────────────────
# Kamida 32 belgidan iborat tasodifiy qator (openssl rand -hex 32)
JWT_SECRET_KEY=CHANGE_ME_jwt_secret_key_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── FastAPI / Ilova ─────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=1

# SQL so'rovlarini konsolga chiqarish (faqat debug uchun; production da false qoldiring)
# app_debug dan mustaqil — alohida nazorat qilish mumkin
SQL_ECHO=false

# CORS — vergul bilan ajratilgan ro'yxat
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,tauri://localhost

# ─── Kuzatuvchanlik ──────────────────────────────────────────
LOG_LEVEL=INFO
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
SENTRY_DSN=

# ─── FCM / APNs (push, B3 da kerak) ─────────────────────────
FCM_SERVER_KEY=CHANGE_ME_fcm_server_key
APNS_KEY_ID=CHANGE_ME_apns_key_id
APNS_TEAM_ID=CHANGE_ME_apns_team_id
