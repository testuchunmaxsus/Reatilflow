# ============================================================
# RETAIL — .env.prod.example
# Production muhit o'zgaruvchilari (placeholder'lar).
#
# Ishlatish:
#   cp .env.prod.example .env.prod
#   # .env.prod ni REAL qiymatlar bilan to'ldiring
#   chmod 600 .env.prod
#
# OGOHLANTIRISH: .env.prod hech qachon git'ga qo'shilmasin!
#                .gitignore ga qo'shilganligini tekshiring.
# ============================================================

# ─── Domain ──────────────────────────────────────────────────
DOMAIN=retail.example.com

# ─── GitHub Container Registry ──────────────────────────────
GITHUB_REPOSITORY=your-org/retail
IMAGE_TAG=latest

# ─── PostgreSQL Primary ──────────────────────────────────────
POSTGRES_DB=retail
POSTGRES_USER=retail_user
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD_MIN_32_CHARS

# Async DSN — api/worker servislar uchun
DATABASE_URL=postgresql+asyncpg://retail_user:REPLACE_WITH_STRONG_PASSWORD_MIN_32_CHARS@postgres-primary:5432/retail

# Read replica DSN — statistika/katalog o'qish uchun
DATABASE_REPLICA_URL=postgresql+asyncpg://retail_user:REPLACE_WITH_STRONG_PASSWORD_MIN_32_CHARS@postgres-replica:5432/retail

# ─── TimescaleDB (GPS) ───────────────────────────────────────
TIMESCALE_DB=retail_gps
TIMESCALE_USER=retail_gps_user
TIMESCALE_PASSWORD=REPLACE_WITH_STRONG_TIMESCALE_PASSWORD

TIMESCALE_URL=postgresql+asyncpg://retail_gps_user:REPLACE_WITH_STRONG_TIMESCALE_PASSWORD@timescaledb:5432/retail_gps

# ─── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=REPLACE_WITH_STRONG_REDIS_PASSWORD
REDIS_URL=redis://:REPLACE_WITH_STRONG_REDIS_PASSWORD@redis:6379/0
REDIS_MAXMEMORY=1gb

# ─── MinIO (Object Storage) ──────────────────────────────────
MINIO_ROOT_USER=REPLACE_WITH_MINIO_ACCESS_KEY
MINIO_ROOT_PASSWORD=REPLACE_WITH_MINIO_SECRET_KEY_MIN_16_CHARS
MINIO_ENDPOINT_URL=http://minio:9000
MINIO_BUCKET_PRODUCTS=retail-products
MINIO_BUCKET_CONTRACTS=retail-contracts
MINIO_BUCKET_PROOFS=retail-delivery-proofs

# CDN eslatmasi: production'da MINIO_CDN_URL o'rnatish mumkin (CloudFront, Cloudflare)
# MINIO_CDN_URL=https://cdn.retail.example.com

# ─── Secrets (JWT + PII) ─────────────────────────────────────
# Generatsiya: openssl rand -hex 32
JWT_SECRET_KEY=REPLACE_WITH_64_HEX_CHARS_openssl_rand_hex_32

# PII shifrlash kalitlari (AES-GCM, 64 hex = 32 bayt)
# Generatsiya: openssl rand -hex 32
PII_ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHARS_openssl_rand_hex_32
BLIND_INDEX_KEY=REPLACE_WITH_64_HEX_CHARS_openssl_rand_hex_32

# JWT sozlamalari
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── FastAPI ─────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
API_WORKERS=2
CORS_ORIGINS=https://retail.example.com,https://admin.retail.example.com

# ─── Push bildirishnomalar ───────────────────────────────────
FCM_SERVER_KEY=REPLACE_WITH_FCM_SERVER_KEY
APNS_KEY_ID=REPLACE_WITH_APNS_KEY_ID
APNS_TEAM_ID=REPLACE_WITH_APNS_TEAM_ID

# ─── Kuzatuvchanlik ──────────────────────────────────────────
LOG_LEVEL=INFO

# OpenTelemetry (ixtiyoriy — bo'sh qoldirilsa OTel o'chiq)
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces

# Sentry (ixtiyoriy — bo'sh qoldirilsa Sentry o'chiq)
SENTRY_DSN=

# ─── Grafana ─────────────────────────────────────────────────
# Generatsiya: openssl rand -base64 16
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=REPLACE_WITH_GRAFANA_ADMIN_PASSWORD

# ─── Prometheus ──────────────────────────────────────────────
PROMETHEUS_RETENTION=30d
